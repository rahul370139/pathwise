# Copy to `backend.env` on the VPS (do not commit real secrets)
#
#   cp backend.env.example backend.env
#   nano backend.env

GROQ_API_KEY=
COHERE_API_KEY=

# Supabase (backend uses the same env var names as the frontend integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Microsoft Foundry IQ — citation-backed grounding (Creative Apps requirement)
FOUNDRY_SEARCH_ENDPOINT=
FOUNDRY_SEARCH_KEY=
FOUNDRY_INDEX=prepkb-index
# FOUNDRY_SEMANTIC_CONFIG=
# FOUNDRY_FIELD_CONTENT=
# FOUNDRY_FIELD_TITLE=
# FOUNDRY_FIELD_SOURCE=

# Optional: extra frontend origins (comma-separated). Defaults already include pathwise-jade.vercel.app + localhost.
# CORS_ORIGINS=https://your-custom-domain.com
