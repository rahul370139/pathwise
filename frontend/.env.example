# ── Local development (copy to frontend/.env.local) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Backend (local uvicorn)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: used for SSR/auth redirect hints when window is unavailable
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Vercel (frontend) ───────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# API_PROXY_TARGET=http://YOUR_HOSTINGER_VPS_IP:8000
# NEXT_PUBLIC_API_BASE_URL=http://YOUR_HOSTINGER_VPS_IP:8000
# NEXT_PUBLIC_SITE_URL=https://pathwise001.vercel.app

# ── Hostinger / VPS (backend) ───────────────────────────────────────────────
# GROQ_API_KEY=...
# COHERE_API_KEY=...
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# FOUNDRY_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
# FOUNDRY_SEARCH_KEY=...
# FOUNDRY_INDEX=prepkb-index
# CORS_ORIGINS=https://your-custom-domain.com,https://pathwise001.vercel.app

# ── Supabase Dashboard (Authentication → URL configuration) ─────────────────
# Site URL:        https://pathwise001.vercel.app  (or your custom domain)
# Redirect URLs:   http://localhost:3000/auth/callback
#                  https://pathwise001.vercel.app/auth/callback
#                  https://YOUR_CUSTOM_DOMAIN/auth/callback
